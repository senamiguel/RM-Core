<Window x:Class="RM_Core.ToastPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="360"
        Height="90"
        WindowStartupLocation="Manual">

  <Border x:Name="borda" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="10" Padding="14,0,14,0">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Width="44" Height="44" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0" VerticalAlignment="Center">
        <Image Source="pack://application:,,,/RM_CORE.ico" Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality"/>
      </Border>

      <StackPanel Grid.Column="1" VerticalAlignment="Center">
        <TextBlock x:Name="txtTitulo" Text="RM Core" FontSize="13" FontWeight="SemiBold" Foreground="#E6FFFFFF" TextTrimming="CharacterEllipsis"/>
        <TextBlock x:Name="txtMensagem" Text="" FontSize="11" Foreground="#B3FFFFFF" Margin="0,4,0,0" TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
