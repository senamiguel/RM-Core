            <StackPanel Margin="0,0,18,0">
              
              <!-- Connection List Section -->
              <TextBlock Text="CONEXÕES ATIVAS" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,0,0,8"/>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="6" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearchBase" Height="30" ui:ControlHelper.CornerRadius="6" ui:ControlHelper.PlaceholderText="Pesquisar base..." Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" TextChanged="txtSearchBase_TextChanged"/>
                <Button x:Name="btnOrdenarBases" Grid.Column="2" Width="34" Height="30" Style="{StaticResource PremiumCardButtonStyle}" ToolTip="Ordenar A-Z" Click="btnOrdenarBases_Click">
                  <TextBlock x:Name="txtSortIcon" Text="A-Z" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E6FFFFFF"/>
                </Button>
              </Grid>
              <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" ClipToBounds="True">
                <ListBox x:Name="lstBases" Height="140" Background="Transparent" BorderThickness="0" 
                         SelectionChanged="lstBases_SelectionChanged">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="2,2,2,2">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="colorDot" Width="10" Height="10" Fill="Transparent" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding name}" VerticalAlignment="Center" Foreground="#E6FFFFFF"/>
                        <Button Grid.Column="2" Width="18" Height="18" Background="Transparent" BorderThickness="0" Click="btnToggleBaseFavorito_Click" ToolTip="Definir como base padr�o" VerticalAlignment="Center">
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#FFC107" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE735;"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                    <Setter Property="Text" Value="&#xE734;"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                        </Button>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
              
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="btnNovaBase" Grid.Column="0" Style="{StaticResource PremiumCardButtonStyle}" Content="+ Nova Base" Click="btnNovaBase_Click" HorizontalAlignment="Stretch" Height="34"/>
              </Grid>

              <!-- Detail Editor (hidden when no connection is selected) -->
              <StackPanel x:Name="stackDetailsEditor" Visibility="Collapsed">
                
                <!-- Card 1: Detalhes da Conexão -->
                <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Margin="0,0,0,15">
                  <StackPanel>
                    <!-- Provider Toggle -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="PROVEDOR"/>
                    <Border Background="#0A0A0B" CornerRadius="8" Padding="2" HorizontalAlignment="Left" Margin="0,0,0,12">
                      <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="rbSql" Content="MS SQL Server" Style="{StaticResource SegmentRadioButtonStyle}" IsChecked="True" GroupName="DbProviderGroup" Checked="rbDbProvider_Checked"/>
                        <RadioButton x:Name="rbOracle" Content="Oracle" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="DbProviderGroup" Checked="rbDbProvider_Checked"/>
                      </StackPanel>
                    </Border>

                    <!-- Nome do Alias -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="NOME DO ALIAS"/>
                    <TextBox x:Name="txtDbAliasName" Height="34" ui:ControlHelper.CornerRadius="6" ui:ControlHelper.PlaceholderText="Ex: ALIAS_TREINAMENTO" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" Margin="0,0,0,12"/>

                    <!-- Cliente Associado / Perfil -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="CLIENTE ASSOCIADO / PERFIL"/>
                    <ComboBox x:Name="cbClienteAssociado" Height="34" ui:ControlHelper.CornerRadius="6" HorizontalAlignment="Stretch" Margin="0,0,0,12" IsEnabled="False"/>

                    <!-- Color Tag Selector -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="MARCADOR DE COR"/>
                    <Border Background="#0A0A0B" CornerRadius="8" Padding="6,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                      <StackPanel Orientation="Horizontal">
                        <Border x:Name="colorTagGreen" Width="22" Height="22" CornerRadius="11" Background="#4CAF50" BorderBrush="Transparent" BorderThickness="2" MouseDown="colorTagSelector_MouseDown" Tag="green" ToolTip="Verde" Margin="2,0"/>
                        <Border x:Name="colorTagYellow" Width="22" Height="22" CornerRadius="11" Background="#FFC107" BorderBrush="Transparent" BorderThickness="2" MouseDown="colorTagSelector_MouseDown" Tag="yellow" ToolTip="Amarelo" Margin="2,0"/>
                        <Border x:Name="colorTagRed" Width="22" Height="22" CornerRadius="11" Background="#F44336" BorderBrush="Transparent" BorderThickness="2" MouseDown="colorTagSelector_MouseDown" Tag="red" ToolTip="Vermelho" Margin="2,0"/>
                      </StackPanel>
                    </Border>

                    <!-- Versão da Base (RM) -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="VERSÃO DA BASE (RM)"/>
                    <ComboBox x:Name="cbDbVersion" Height="34" ui:ControlHelper.CornerRadius="6" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                    <!-- Usuário RM and Senha RM -->
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="USUÁRIO RM"/>
                        <TextBox x:Name="txtRmUser" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White"/>
                      </StackPanel>

                      <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="SENHA RM"/>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <PasswordBox x:Name="pbRmPass" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" MinWidth="130"/>
                          <TextBox x:Name="txtRmPassVisible" Grid.Column="0" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,30,0" CaretBrush="White" Visibility="Collapsed" MinWidth="130"/>
                          <Button x:Name="btnToggleRmPass" Grid.Column="1" Width="32" Height="32" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Click="btnTogglePass_Click" Tag="rm" ToolTip="Mostrar/ocultar senha" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock x:Name="iconToggleRmPass" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B3FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </Grid>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Card 2: Configurações Avançadas -->
                <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Margin="0,0,0,15">
                  <StackPanel>
                    <TextBlock Text="CONFIGURAÇÕES AVANÇADAS" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,0,0,12"/>

                    <!-- Servidor de Banco (Host) -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="SERVIDOR DE BANCO (HOST)"/>
                    <TextBox x:Name="txtDbServer" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" Margin="0,0,0,12"/>

                    <!-- Nome da Base de Dados (SQL) -->
                    <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="NOME DA BASE DE DADOS" x:Name="lblDbBaseName"/>
                    <TextBox x:Name="txtDbBaseName" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" Margin="0,0,0,12"/>

                    <!-- Usuário Banco and Senha Banco -->
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="USUÁRIO BANCO"/>
                        <TextBox x:Name="txtDbUser" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White"/>
                      </StackPanel>

                      <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="SENHA BANCO"/>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <PasswordBox x:Name="pbDbPass" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,8,0" CaretBrush="White" MinWidth="130"/>
                          <TextBox x:Name="txtDbPassVisible" Grid.Column="0" Height="34" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" Padding="8,0,30,0" CaretBrush="White" Visibility="Collapsed" MinWidth="130"/>
                          <Button x:Name="btnToggleDbPass" Grid.Column="1" Width="32" Height="32" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Click="btnTogglePass_Click" Tag="db" ToolTip="Mostrar/ocultar senha" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock x:Name="iconToggleDbPass" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B3FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Button>
                        </Grid>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Card 3: Serviços de Job -->
                <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Margin="0,0,0,5">
                  <StackPanel>
                    <TextBlock Text="SERVIÇOS DE JOB" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,0,0,12"/>

                    <!-- Checkboxes -->
                    <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                      <StackPanel>
                        <CheckBox x:Name="chkRunService" Content="RunService" Foreground="White" IsChecked="True" Margin="0,0,0,10"/>
                        <CheckBox x:Name="chkJobProcessing" Content="Habilitar Processamento de Jobs" Foreground="White" Margin="0,0,0,10"/>
                        <CheckBox x:Name="chkLocalOnly" Content="Executar Apenas Jobs Locais" Foreground="White" Margin="0,0,0,10"/>
                        <CheckBox x:Name="chkProcessPool" Content="Habilitar pool de processos" Foreground="White"/>
                      </StackPanel>
                    </Border>

                    <!-- Execuções Simultâneas -->
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Execuções Simultâneas" Foreground="White" VerticalAlignment="Center"/>
                      <TextBox x:Name="txtMaxThreads" Grid.Column="1" Width="80" Height="30" ui:ControlHelper.CornerRadius="4" Background="#1FFFFFFF" BorderBrush="#33FFFFFF" Foreground="White" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="4,0,4,0" CaretBrush="White"/>
                    </Grid>
                  </StackPanel>
                </Border>
                
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <!-- Sticky Bottom Action Bar (Row 2, does not scroll) -->
          <Border Grid.Row="2" x:Name="borderActionBar" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="0,12,0,0" Margin="0,10,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Button x:Name="btnSalvarBase" Grid.Column="0" Height="38" ui:ControlHelper.CornerRadius="6" Style="{StaticResource PremiumPrimaryButtonStyle}" Content="Salvar Alterações" Click="btnSalvarBase_Click" FontWeight="SemiBold"/>
              <Button x:Name="btnTestarConexao" Grid.Column="2" Height="38" ui:ControlHelper.CornerRadius="6" Style="{StaticResource PremiumCardButtonStyle}" Content="Testar Conexão" Click="btnTestarConexao_Click" FontWeight="SemiBold"/>
              <Button x:Name="btnDuplicarBase" Grid.Column="4" Width="38" Height="38" ui:ControlHelper.CornerRadius="6" Style="{StaticResource PremiumCardButtonStyle}" ToolTip="Duplicar Base" Click="btnDuplicarBase_Click">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
              <Button x:Name="btnDeletarBase" Grid.Column="6" Width="38" Height="38" ui:ControlHelper.CornerRadius="6" Style="{StaticResource PremiumRedButtonStyle}" ToolTip="Remover Alias" Click="btnDeletarBase_Click">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>
        </Grid>
        </Grid>

      <!-- Tab 4: SOBRE -->
      <Grid x:Name="gridTabSobre" Visibility="Collapsed" Margin="18,15,18,15">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,20">

            <!-- Header -->
            <Image Source="pack://application:,,,/RM_CORE.ico" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,20,0,12" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="RM Core" FontSize="22" FontWeight="Bold" Foreground="#E6FFFFFF" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtVersaoApp" Text="Versão 1.0.0" FontSize="11" Foreground="#80FFFFFF" HorizontalAlignment="Center"/>
            <TextBlock Text="Central de comando para ambientes TOTVS RM" FontSize="11" Foreground="#4DA6FF" HorizontalAlignment="Center" Margin="0,6,0,0"/>

            <!-- Card: VERSÃO -->
            <TextBlock Text="VERSÃO" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,24,0,8" HorizontalAlignment="Left" Width="320"/>
            <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Width="320" HorizontalAlignment="Center">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VERSÃO ATUAL" FontSize="10" Foreground="#80FFFFFF" Margin="0,0,0,2"/>
                    <TextBlock x:Name="txtVersaoPanel" Text="v1.0.0" FontSize="20" FontWeight="Bold" Foreground="#E6FFFFFF"/>
                  </StackPanel>
                  <Button x:Name="btnCheckUpdate" Grid.Column="1" Width="36" Height="36" Style="{StaticResource PremiumCardButtonStyle}" ToolTip="Verificar atualizações" Click="btnCheckUpdate_Click" VerticalAlignment="Center">
                    <Grid>
                      <TextBlock x:Name="txtRefreshIcon" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                  </Button>
                </Grid>

                <TextBlock x:Name="txtVersionStatus" Text="Verificando..." FontSize="12" Foreground="#80FFFFFF" Margin="0,10,0,0"/>

                <!-- Update available section (hidden when up to date) -->
                <Border x:Name="bordaNovaVersao" Visibility="Collapsed" Background="#0C10B981" BorderBrush="#1A10B981" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="txtUpdateVersion" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Button x:Name="btnBaixarUpdate" Style="{StaticResource PremiumPrimaryButtonStyle}" Content="Baixar Atualização" Click="btnBaixarUpdate_Click" Height="34" FontSize="11"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <!-- Reconfigurar (botão pra forçar wizard) -->
            <Button x:Name="btnReconfigurar" Content="Reconfigurar (wizard)" Click="btnReconfigurar_Click" Margin="0,20,0,0" Width="320" Height="38"
                    Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" Foreground="#E6FFFFFF" FontSize="12" FontWeight="SemiBold">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="border" Property="Background" Value="#16FFFFFF"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Card: PADRÃO (cliente e base que iniciam automaticamente) -->
            <TextBlock Text="PADRÃO" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,24,0,8" HorizontalAlignment="Left" Width="320"/>
            <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Width="320" HorizontalAlignment="Center">
              <StackPanel>
                <TextBlock FontSize="11" Foreground="#80FFFFFF" TextWrapping="Wrap" Margin="0,0,0,12" Text="Cliente e base que abrem automaticamente ao iniciar. Se vazio, o app lembra do último usado."/>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0" HorizontalAlignment="Stretch">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="CLIENTE PADRÃO" Margin="0,0,0,6"/>
                    <ComboBox x:Name="cbDefaultClient" Height="38" FontSize="12" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" Foreground="White" Padding="10,0,10,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" SelectionChanged="cbDefaultClient_SelectionChanged"/>
                  </StackPanel>

                  <StackPanel Grid.Column="2" HorizontalAlignment="Stretch">
                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Text="BASE PADRÃO" Margin="0,0,0,6"/>
                    <ComboBox x:Name="cbDefaultBase" Height="38" FontSize="12" ui:ControlHelper.CornerRadius="6" Background="#1FFFFFFF" Foreground="White" Padding="10,0,10,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsEnabled="False" DisplayMemberPath="name" SelectionChanged="cbDefaultBase_SelectionChanged"/>
                  </StackPanel>
                </Grid>

                <Button x:Name="btnLimparPadrao" Style="{StaticResource PremiumCardButtonStyle}" Content="Limpar padrão" Click="btnLimparPadrao_Click" Height="36" FontSize="12" Margin="0,14,0,0"/>
              </StackPanel>
            </Border>

            <!-- Configurações -->
            <TextBlock Text="CONFIGURAÇÕES" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,24,0,8" HorizontalAlignment="Left" Width="320"/>
            <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,8,15,8" Width="320" HorizontalAlignment="Center">
              <StackPanel>

                <Grid Margin="0,8,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#E6FFFFFF" Text="Fechar minimiza pro tray"/>
                    <TextBlock FontSize="10" Foreground="#80FFFFFF" Text="X esconde; Sair pelo menu encerra" Margin="0,2,0,0" TextWrapping="Wrap"/>
                  </StackPanel>
                  <ui:ToggleSwitch x:Name="tsCloseMinimizesToTray" Grid.Column="1" OffContent="" OnContent="" MinWidth="0" IsOn="True" Toggled="tsAppSetting_Toggled"/>
                </Grid>

                <Border BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0" />

                <Grid Margin="0,8,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#E6FFFFFF" Text="Iniciar com o Windows"/>
                    <TextBlock FontSize="10" Foreground="#80FFFFFF" Text="Adiciona atalho no startup" Margin="0,2,0,0"/>
                  </StackPanel>
                  <ui:ToggleSwitch x:Name="tsStartWithWindows" Grid.Column="1" OffContent="" OnContent="" MinWidth="0" IsOn="False" Toggled="tsAppSetting_Toggled"/>
                </Grid>

                <Border BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0" />

                <Grid Margin="0,8,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#E6FFFFFF" Text="Iniciar minimizado"/>
                    <TextBlock FontSize="10" Foreground="#80FFFFFF" Text="Sobe direto pro tray ao abrir" Margin="0,2,0,0"/>
                  </StackPanel>
                  <ui:ToggleSwitch x:Name="tsStartMinimized" Grid.Column="1" OffContent="" OnContent="" MinWidth="0" IsOn="False" Toggled="tsAppSetting_Toggled"/>
                </Grid>

              </StackPanel>
            </Border>

            <!-- Importar / Exportar / Reset -->
            <TextBlock Text="DADOS" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,18,0,8" HorizontalAlignment="Left" Width="320"/>
            <Grid Width="320" HorizontalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button x:Name="btnExportar" Grid.Column="0" Style="{StaticResource PremiumCardButtonStyle}" Content="Exportar" Click="btnExportar_Click" Height="38" FontSize="12"/>
              <Button x:Name="btnImportar" Grid.Column="2" Style="{StaticResource PremiumCardButtonStyle}" Content="Importar" Click="btnImportar_Click" Height="38" FontSize="12"/>
              <Button x:Name="btnResetFabrica" Grid.Column="4" Style="{StaticResource PremiumRedButtonStyle}" Content="Reset de Fabrica" Click="btnResetFabrica_Click" Height="38" FontSize="11"/>
            </Grid>

            <!-- Card: DESENVOLVEDOR -->
            <TextBlock Text="DESENVOLVEDOR" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,18,0,8" HorizontalAlignment="Left" Width="320"/>
            <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12" Width="320" HorizontalAlignment="Center">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="44" Height="44" CornerRadius="22" Background="#27272A" Margin="0,0,12,0">
                  <Image Source="https://github.com/senamiguel.png" Width="44" Height="44" RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Clip>
