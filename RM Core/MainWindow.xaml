<Window x:Class="RM_Core.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RM_Core"
        
        xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.Height="36"
        ui:TitleBar.IsIconVisible="True"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="RM Core" Height="710" Width="450" 
        Icon="pack://application:,,,/RM_CORE.ico"
        Background="#1C1C1E"
        FontFamily="Inter, Segoe UI, Arial"
        FontSize="14">

  <Window.Resources>
    <Style x:Key="BottomTabStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#80FFFFFF"/>
      <Setter Property="Height" Value="54"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="TabBorder" Background="Transparent" CornerRadius="10" Padding="6,6,6,6" Margin="4,2,4,2">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TabIcon" Text="{TemplateBinding Content}" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                <TextBlock x:Name="TabLabel" Text="{TemplateBinding Tag}" FontSize="9" FontWeight="Bold" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="#1A0078D4"/>
                <Setter Property="Foreground" Value="#4DA6FF"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True"/>
                  <Condition Property="IsChecked" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="TabBorder" Property="Background" Value="#2B0078D4"/>
                <Setter Property="Foreground" Value="#80C0FF"/>
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True"/>
                  <Condition Property="IsChecked" Value="False"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="TabBorder" Property="Background" Value="#0DFFFFFF"/>
                <Setter Property="Foreground" Value="#E6FFFFFF"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PremiumCardButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#0CFFFFFF"/>
      <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="5"/>
      <Setter Property="Foreground" Value="#E6FFFFFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform X="0" Y="0"/>
        </Setter.Value>
      </Setter>
      
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="true">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
            
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#16FFFFFF" Duration="0:0:0.2"/>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                      To="#40FFFFFF" Duration="0:0:0.2"/>
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                       To="-3" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0CFFFFFF" Duration="0:0:0.2"/>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                      To="#1AFFFFFF" Duration="0:0:0.2"/>
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                       To="0" Duration="0:0:0.15" AccelerationRatio="0.8"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#60FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PremiumRedButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#2D2D30"/>
      <Setter Property="BorderBrush" Value="#3F3F46"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#FF4D4D"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform X="0" Y="0"/>
        </Setter.Value>
      </Setter>
      
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    SnapsToDevicePixels="true">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
            
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#3D2D30" Duration="0:0:0.2"/>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                      To="#FF4D4D" Duration="0:0:0.2"/>
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                       To="-3" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#2D2D30" Duration="0:0:0.2"/>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                      To="#3F3F46" Duration="0:0:0.2"/>
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                       To="0" Duration="0:0:0.15" AccelerationRatio="0.8"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#4D2D30"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#FF3333"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PremiumMainButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#0078D4"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6,0,0,6"
                    SnapsToDevicePixels="true">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0086F0" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0078D4" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PremiumDropdownButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#0063B1"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="0,6,6,0"
                    SnapsToDevicePixels="true">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0072C6" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0063B1" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#004B87"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="LiftGridStyle" TargetType="Grid">
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform X="0" Y="0"/>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                               To="-3" Duration="0:0:0.15" DecelerationRatio="0.8"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                               To="0" Duration="0:0:0.15" AccelerationRatio="0.8"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SegmentRadioButtonStyle" TargetType="RadioButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#80FFFFFF"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="border" Property="Background" Value="#212124"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#0078D4"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    SnapsToDevicePixels="true">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0086F0" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="border"
                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                      To="#0078D4" Duration="0:0:0.2"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="Auto" MinHeight="78.04" />
    </Grid.RowDefinitions>

    <!-- CONTENT AREA -->
    <Grid Grid.Row="0">

      <!-- Tab 1: INÍCIO -->
      <Grid x:Name="gridTabInicio" Visibility="Visible">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. SELECTORS (FIXED HEADER) -->
        <Grid Grid.Row="0" Margin="18,15,18,15">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="191*" />
            <ColumnDefinition Width="9*"/>
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="200*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Grid.ColumnSpan="2">
            <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF"><Run Language="pt-br" Text="CLIENTE ATIVO"/></TextBlock>
            <ComboBox x:Name="cbClienteAtivo" HorizontalAlignment="Stretch" Height="34" ui:ControlHelper.CornerRadius="6" SelectionChanged="cbClienteAtivo_SelectionChanged"/>
          </StackPanel>

          <StackPanel Grid.Column="3">
            <TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF"><Run Text="BASE"/></TextBlock>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ComboBox x:Name="cbBase" HorizontalAlignment="Stretch" Height="34" ui:ControlHelper.CornerRadius="6" SelectionChanged="cbBase_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Ellipse Width="10" Height="10" Fill="{Binding TagColor, Converter={StaticResource TagColorConverter}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                      <TextBlock Grid.Column="1" Text="{Binding name}" VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button x:Name="btnEditarBaseHome" Grid.Column="2" Width="34" Height="34" Style="{StaticResource PremiumCardButtonStyle}" ToolTip="Editar base selecionada" Click="btnEditarBaseHome_Click">
                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </StackPanel>
        </Grid>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <ikw:SimpleStackPanel Spacing="20" VerticalAlignment="Top" Margin="18,0,18,15">

            <!-- 2. QUICK SETTINGS -->
            <StackPanel>
              <TextBlock Text="QUICK SETTINGS" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,0,0,8"/>
              <Border Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="15,12,15,12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <DockPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" LastChildFill="False">
                    <ui:ToggleSwitch x:Name="tsLimparBrokers" DockPanel.Dock="Right" OffContent="" OnContent="" MinWidth="0" Margin="6,0,0,0" Toggled="ts_Toggled" IsOn="True" VerticalAlignment="Center"/>
                    <TextBlock Text="Deletar Broker Custom" FontSize="10" FontWeight="Medium" Foreground="#E6FFFFFF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  </DockPanel>

                  <DockPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" LastChildFill="False">
                    <ui:ToggleSwitch x:Name="tsLogsDetalhados" DockPanel.Dock="Right" IsOn="False" OffContent="" OnContent="" MinWidth="0" Margin="6,0,0,0" Toggled="ts_Toggled" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="Logs Detalhados" FontSize="10" FontWeight="Medium" Foreground="#E6FFFFFF" VerticalAlignment="Center"/>
                      <Border Background="#0078D4" CornerRadius="3" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DBG" FontSize="8" FontWeight="Bold" Foreground="White"/>
                      </Border>
                    </StackPanel>
                  </DockPanel>

                  <DockPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" LastChildFill="False">
                    <ui:ToggleSwitch x:Name="tsDeletarBrokerDat" DockPanel.Dock="Right" OffContent="" OnContent="" MinWidth="0" Margin="6,0,0,0" Toggled="ts_Toggled" IsOn="True" VerticalAlignment="Center"/>
                    <TextBlock Text="Deletar Broker" FontSize="10" FontWeight="Medium" Foreground="#E6FFFFFF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  </DockPanel>
                </Grid>
              </Border>
            </StackPanel>

            <!-- 3. MASTER ACTIONS -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <!-- Iniciar Ambiente Completo (Split-Button Grid) -->
              <Grid Grid.Column="0" Grid.ColumnSpan="5" Style="{StaticResource LiftGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Main Button -->
                <Button x:Name="btnIniciarCompleto" Grid.Column="0" 
                        Style="{StaticResource PremiumMainButtonStyle}"
                        Height="42" FontSize="13" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Click="btnIniciarCompleto_Click">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" Text="Iniciar RM + Host"/>
                  </StackPanel>
                </Button>

                <!-- Dropdown Arrow Button -->
                <Button x:Name="btnIniciarDropdown" Grid.Column="1" Width="32"
                        Style="{StaticResource PremiumDropdownButtonStyle}"
                        Height="42" Click="btnIniciarDropdown_Click" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                  <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button.ContextMenu>
                    <ContextMenu x:Name="menuIniciarSeparado">
                      <MenuItem Header="Iniciar Somente RM" Click="menuIniciarRM_Click"/>
                      <MenuItem Header="Iniciar Somente Host Principal" Click="menuIniciarHostPrincipal_Click"/>
                      <MenuItem Header="Iniciar Somente Host 2" Click="menuIniciarHost2_Click"/>
                      <MenuItem Header="Abrir Portal do Aluno" Click="menuIniciarPortalAluno_Click"/>
                    </ContextMenu>
                  </Button.ContextMenu>
                </Button>
              </Grid>

              <!-- Derrubar -->
              <Button x:Name="btnDerrubarTudo" Grid.Column="6" HorizontalAlignment="Stretch"
                      Style="{StaticResource PremiumRedButtonStyle}" Click="btnDerrubarTudo_Click"
                      ToolTip="Derrubar todos os processos">
                <TextBlock Text="&#xE10A;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </Grid>

            <!-- 4. ATALHOS -->
            <StackPanel>
              <TextBlock Text="ATALHOS" FontSize="11" FontWeight="SemiBold" Foreground="#80FFFFFF" Margin="0,0,0,10"/>

              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="8" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Primeira linha: 4 cartões individuais -->

                <!-- Pasta Custom Card -->
                <Button x:Name="btnCustom" Grid.Row="0" Grid.Column="0" Height="80"
                        Style="{StaticResource PremiumCardButtonStyle}"
                        Click="btnCustom_Click" HorizontalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#E6FFFFFF"/>
                    <TextBlock FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#E6FFFFFF"><Run Language="pt-br" Text="Pasta Custom"/></TextBlock>
                  </StackPanel>
                </Button>

                <!-- Bases Card -->
                <Button x:Name="btnAliases" Grid.Row="0" Grid.Column="2" Height="80"
                        Style="{StaticResource PremiumCardButtonStyle}"
                        Click="btnAliases_Click" HorizontalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xEC27;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#E6FFFFFF"/>
                    <TextBlock Text="Bases" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#E6FFFFFF"/>
                  </StackPanel>
                </Button>

                <!-- BIN Card -->
                <Button x:Name="btnBin" Grid.Row="0" Grid.Column="4" Height="80"
                        Style="{StaticResource PremiumCardButtonStyle}"
                        Click="btnBin_Click" HorizontalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#E6FFFFFF"/>
                    <TextBlock Text="Pasta BIN" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#E6FFFFFF"/>
                  </StackPanel>
                </Button>

                <!-- DEL. DLL Card -->
                <Button x:Name="btnDelDll" Grid.Row="0" Grid.Column="6" Height="80"
                        Style="{StaticResource PremiumCardButtonStyle}"
                        Click="btnDelDll_Click" HorizontalAlignment="Stretch">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE108;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#E6FFFFFF"/>
                    <TextBlock Text="DEL. DLL" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#E6FFFFFF"/>
                  </StackPanel>
                </Button>

                <!-- Segunda linha: 2 botões compridos (Instalar Dual Host + Validar DLLs) -->

                <!-- Instalar Dual Host Card -->
